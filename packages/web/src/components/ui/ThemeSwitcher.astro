---
const themes = [
  { id: 'dark', label: 'JWT Dark', color: '#fb015b' },
  { id: 'light', label: 'Light', color: '#d4004a' },
  { id: 'dracula', label: 'Dracula', color: '#ff79c6' },
  { id: 'nord', label: 'Nord', color: '#bf616a' },
  { id: 'catppuccin', label: 'Catppuccin', color: '#f38ba8' },
  { id: 'synthwave', label: 'Synthwave', color: '#ff2e97' },
  { id: 'matrix', label: 'Matrix', color: '#00ff41' },
  { id: 'bloodmoon', label: 'Blood Moon', color: '#ff0040' },
  { id: 'midnight', label: 'Midnight', color: '#e8457c' },
  { id: 'gruvbox', label: 'Gruvbox', color: '#fabd2f' },
  { id: 'cyberpunk', label: 'Cyberpunk', color: '#ff2e97' },
  { id: 'nebula', label: 'Nebula', color: '#e040fb' },
  { id: 'solarized', label: 'Solarized', color: '#dc322f' },
  { id: 'rosepine', label: 'Rose Pine', color: '#ea9a97' },
  { id: 'monokai', label: 'Monokai', color: '#a6e22e' },
];
---
<div class="theme-switcher">
  <button id="theme-toggle-btn" class="btn-ghost focus-ring" aria-haspopup="true" aria-expanded="false" aria-label="Choose theme">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
  </button>
  <div id="theme-dropdown" class="theme-dropdown" role="listbox" aria-label="Theme options">
    {themes.map((t) => (
      <button class="theme-option" data-theme={t.id} role="option" aria-selected="false">
        <span class="theme-dot" style={`background: ${t.color}`}></span>
        <span>{t.label}</span>
      </button>
    ))}
    <div class="theme-divider"></div>
    <button id="theme-random-btn" class="theme-option theme-random">
      <span>🎲</span>
      <span>Random</span>
    </button>
  </div>
</div>

<style>
  .theme-switcher { position: relative; }

  .theme-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-md);
    padding: 0.5rem;
    min-width: 180px;
    z-index: 60;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .theme-dropdown.open { display: block; }

  .theme-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: none;
    background: none;
    color: var(--color-text-secondary);
    font-size: 0.8rem;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: all 0.15s ease;
    font-family: var(--font-body);
  }

  .theme-option:hover { background: color-mix(in srgb, var(--color-brand) 10%, transparent); color: var(--color-text-primary); }
  .theme-option.active { color: var(--color-brand); font-weight: 600; }

  .theme-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .theme-divider {
    height: 1px;
    background: var(--color-border-default);
    margin: 0.25rem 0;
  }
</style>
