---
const managers = [
  { id: 'npm', label: 'npm', quick: 'npx tokx-cli decode <token>', global: 'npm i -g tokx-cli' },
  {
    id: 'pnpm',
    label: 'pnpm',
    quick: 'pnpm dlx tokx-cli decode <token>',
    global: 'pnpm add -g tokx-cli',
  },
  {
    id: 'yarn',
    label: 'yarn',
    quick: 'yarn dlx tokx-cli decode <token>',
    global: 'yarn global add tokx-cli',
  },
  { id: 'bun', label: 'bun', quick: 'bunx tokx-cli decode <token>', global: 'bun add -g tokx-cli' },
  {
    id: 'brew',
    label: 'Homebrew',
    quick: 'brew install hammadxcm/tap/tokx',
    global: 'brew install hammadxcm/tap/tokx',
  },
  { id: 'pip', label: 'pip', quick: 'pip install tokx', global: 'pip install tokx' },
  {
    id: 'cargo',
    label: 'cargo',
    quick: 'cargo binstall tokx-bin',
    global: 'cargo binstall tokx-bin',
  },
  { id: 'snap', label: 'Snap', quick: 'sudo snap install tokx', global: 'sudo snap install tokx' },
  {
    id: 'scoop',
    label: 'Scoop',
    quick: 'scoop install hammadxcm/tokx',
    global: 'scoop install hammadxcm/tokx',
  },
  { id: 'choco', label: 'Chocolatey', quick: 'choco install tokx', global: 'choco install tokx' },
  {
    id: 'winget',
    label: 'winget',
    quick: 'winget install hammadxcm.tokx',
    global: 'winget install hammadxcm.tokx',
  },
];
const apiCommand = "import { decode, encode, verify } from '@tokx/core'";
---

<section class="section-surface" id="install">
  <div class="section">
    <div class="section-header reveal">
      <span class="section-label">install</span>
      <h2 class="section-title">Available on <span class="gradient-text">every platform</span></h2>
      <div class="section-divider"></div>
    </div>

    <div class="pm-tabs reveal" role="tablist" aria-label="Package manager">
      {managers.map((pm, i) => (
        <button
          role="tab"
          id={`pm-tab-${pm.id}`}
          class={`pm-tab-btn ${i === 0 ? 'active' : ''}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-controls={`pm-panel-${pm.id}`}
          tabindex={i === 0 ? 0 : -1}
          type="button"
        >
          {pm.label}
        </button>
      ))}
    </div>

    {managers.map((pm, i) => (
      <div class={`pm-panel ${i === 0 ? 'active' : ''}`} role="tabpanel" id={`pm-panel-${pm.id}`} aria-labelledby={`pm-tab-${pm.id}`} tabindex="0">
        <div class="install-grid">
          <div class="install-block glass">
            <div class="install-label">Quick Start</div>
            <div class="install-code">
              <code>{pm.quick}</code>
              <button class="copy-btn" data-copy={pm.quick} type="button" aria-label="Copy command">
                <span class="copy-icon">&#x2398;</span>
                <span class="copy-check" aria-hidden="true">&#x2713;</span>
              </button>
            </div>
          </div>
          <div class="install-block glass">
            <div class="install-label">Global Install</div>
            <div class="install-code">
              <code>{pm.global}</code>
              <button class="copy-btn" data-copy={pm.global} type="button" aria-label="Copy command">
                <span class="copy-icon">&#x2398;</span>
                <span class="copy-check" aria-hidden="true">&#x2713;</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    ))}

    <div class="install-api-block reveal">
      <div class="install-block glass">
        <div class="install-label">Use as a library</div>
        <div class="install-code">
          <code>{apiCommand}</code>
          <button class="copy-btn" data-copy={apiCommand} type="button" aria-label="Copy import">
            <span class="copy-icon">&#x2398;</span>
            <span class="copy-check" aria-hidden="true">&#x2713;</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pm-tabs { display: flex; gap: 0; margin-bottom: 24px; border-bottom: 2px solid var(--color-border-default); overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .pm-tab-btn { padding: 12px 20px; font-size: 0.85rem; font-weight: 600; color: var(--color-text-secondary); cursor: pointer; border: none; border-bottom: 2px solid transparent; margin-bottom: -2px; transition: color 0.2s, border-color 0.2s; min-height: 44px; display: flex; align-items: center; background: none; font-family: var(--font-mono); white-space: nowrap; }
  .pm-tab-btn:hover { color: var(--color-text-primary); }
  .pm-tab-btn.active { color: var(--color-brand); border-bottom-color: var(--color-brand); }
  .pm-panel { display: none; }
  .pm-panel.active { display: block; }
  .install-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .install-block { border-radius: var(--radius-lg); padding: 24px; }
  .install-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-secondary); margin-bottom: 12px; }
  .install-code { display: flex; align-items: center; justify-content: space-between; gap: 12px; background: var(--color-bg-base); border: 1px solid var(--color-border-default); border-radius: var(--radius-md); padding: 12px 16px; font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-brand-mint); overflow-x: auto; }
  .install-code code { white-space: nowrap; }
  .install-api-block { margin-top: 20px; }
  .copy-btn { flex-shrink: 0; background: none; border: none; color: var(--color-text-secondary); cursor: pointer; font-size: 1rem; padding: 8px; border-radius: 4px; transition: color 0.2s; position: relative; min-width: 44px; min-height: 44px; display: flex; align-items: center; justify-content: center; }
  .copy-btn:hover { color: var(--color-text-primary); }
  .copy-check { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; color: #28c840; opacity: 0; transition: opacity 0.2s; }
  .copy-btn.copied .copy-icon { opacity: 0; }
  .copy-btn.copied .copy-check { opacity: 1; }
  @media (max-width: 768px) { .install-grid { grid-template-columns: 1fr; } .pm-tab-btn { padding: 10px 14px; font-size: 0.75rem; } }
</style>

<script>
  const pmTabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.pm-tab-btn[role="tab"]'));
  const pmPanels = document.querySelectorAll<HTMLElement>('.pm-panel[role="tabpanel"]');
  function activatePmTab(tab: HTMLButtonElement) {
    pmTabs.forEach((t) => { t.setAttribute('aria-selected', 'false'); t.tabIndex = -1; t.classList.remove('active'); });
    tab.setAttribute('aria-selected', 'true'); tab.tabIndex = 0; tab.classList.add('active'); tab.focus();
    const targetId = tab.getAttribute('aria-controls');
    pmPanels.forEach((p) => p.classList.toggle('active', p.id === targetId));
  }
  pmTabs.forEach((tab) => tab.addEventListener('click', () => activatePmTab(tab)));
  document.querySelector('.pm-tabs')?.addEventListener('keydown', (e) => {
    const ev = e as KeyboardEvent; const cur = pmTabs.indexOf(document.activeElement as HTMLButtonElement); let next: number | null = null;
    if (ev.key === 'ArrowRight') next = (cur + 1) % pmTabs.length;
    else if (ev.key === 'ArrowLeft') next = (cur - 1 + pmTabs.length) % pmTabs.length;
    else if (ev.key === 'Home') next = 0; else if (ev.key === 'End') next = pmTabs.length - 1;
    if (next !== null) { ev.preventDefault(); activatePmTab(pmTabs[next]); }
  });
  document.querySelectorAll<HTMLButtonElement>('#install .copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy; if (!text) return;
      try { await navigator.clipboard.writeText(text); } catch { return; }
      btn.classList.add('copied'); setTimeout(() => btn.classList.remove('copied'), 1500);
    });
  });
</script>
